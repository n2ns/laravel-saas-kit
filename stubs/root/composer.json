{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "n2ns/saas-starter",
    "type": "project",
    "description": "Production-tested Laravel SaaS website starter.",
    "keywords": [
        "laravel",
        "saas",
        "product-site",
        "template"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "carbonphp/carbon-doctrine-types": "^3.0",
        "doctrine/dbal": "^4.0",
        "filament/filament": "^5.0",
        "google/apiclient": "^2.15",
        "lara-zeus/spatie-translatable": "^2.0",
        "laravel/cashier": "^16.0",
        "laravel/framework": "^12.0",
        "laravel/passport": "^13.4",
        "laravel/socialite": "^5.24",
        "laravel/tinker": "^2.10.1",
        "league/commonmark": "^2.8",
        "nickbeen/socialiteproviders-google-one-tap": "^1.0",
        "resend/resend-php": "^1.1",
        "socialiteproviders/manager": "^4.9",
        "spatie/laravel-backup": "^9.3",
        "spatie/laravel-markdown": "^2.7",
        "spatie/laravel-sitemap": "^7.3",
        "spatie/laravel-stripe-webhooks": "^3.10",
        "spatie/laravel-translatable": "^6.11",
        "yaza/laravel-google-drive-storage": "^4.1"
    },
    "require-dev": {
        "brianium/paratest": "^7.8",
        "fakerphp/faker": "^1.23",
        "filament/upgrade": "^5.0",
        "larastan/larastan": "^3.8",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.3",
        "phpunit/phpunit": "^12.0",
        "spatie/pest-plugin-snapshots": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "bash scripts/run-local-tests.sh"
        ],
        "test:serial": "@php artisan test",
        "db:restore-local": "@php artisan database:restore-local --force",
        "analyse": "./vendor/bin/phpstan analyse --memory-limit=512M",
        "coverage": "@php artisan test --coverage --min=70",
        "check": [
            "@lint",
            "@pint-test",
            "@analyse",
            "@test",
            "@security-audit"
        ],
        "pint": "./vendor/bin/pint",
        "pint-test": "./vendor/bin/pint --test",
        "lint": "@php scripts/lint-php.php",
        "security-audit": "composer audit --no-dev"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
